    {
      "name": "guard then events — guard call appears in event stream",
      "description": "Multi-step scenario: submits a guard check, then fetches the event list and asserts at least one event exists. Validates the end-to-end write path through the MCP server into the control plane event store.",
      "skip_unless_any_capability": ["tools"],
      "steps": [
        {
          "call_tool": {
            "name": "varden_guard",
            "arguments": {
              "type": "tool_call",
              "tool": "mcp_probe_e2e_tool",
              "agent_name": "mcp-probe",
              "args": { "input": "e2e-trace-check" }
            }
          },
          "expect": {
            "result_schema": {
              "type": "object",
              "required": ["content"],
              "properties": {
                "content": {
                  "type": "array",
                  "minItems": 1
                }
              }
            }
          }
        },
        {
          "call_tool": {
            "name": "varden_get_events",
            "arguments": { "limit": 10, "offset": 0 }
          },
          "expect": {
            "result_schema": {
              "type": "object",
              "required": ["content"],
              "properties": {
                "content": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["type", "text"],
                    "properties": {
                      "type": { "const": "text" },
                      "text": { "type": "string", "minLength": 1 }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }

  ]
