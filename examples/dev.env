VARDEN_ENV=dev
VARDEN_DB_PATH=varden.db
VARDEN_AUTH_DB_PATH=varden_auth.db
VARDEN_POLICY_FILE=policy.json
VARDEN_SIGNING_SECRET=dev-secret-not-for-prod
VARDEN_HOST=127.0.0.1
VARDEN_PORT=8000
VARDEN_QUEUE_BACKEND=sqlite
VARDEN_WORKER_POLL_INTERVAL=1.0
VARDEN_WORKER_CONCURRENCY=1
VARDEN_RATE_LIMIT_PER_MINUTE=60
VARDEN_ROUTE_SENSITIVE_LOCAL=false
VARDEN_SCAN_MODE=deep
