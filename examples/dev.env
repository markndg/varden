SENTINEL_ENV=dev
SENTINEL_DB_PATH=sentinel.db
SENTINEL_AUTH_DB_PATH=sentinel_auth.db
SENTINEL_POLICY_FILE=policy.json
SENTINEL_SIGNING_SECRET=dev-secret-not-for-prod
SENTINEL_HOST=127.0.0.1
SENTINEL_PORT=8000
SENTINEL_QUEUE_BACKEND=sqlite
SENTINEL_WORKER_POLL_INTERVAL=1.0
SENTINEL_WORKER_CONCURRENCY=1
SENTINEL_RATE_LIMIT_PER_MINUTE=60
SENTINEL_ROUTE_SENSITIVE_LOCAL=false
SENTINEL_SCAN_MODE=deep
