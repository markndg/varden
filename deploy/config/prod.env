SENTINEL_ENV=prod
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8000
SENTINEL_DB_PATH=/data/sentinel.db
SENTINEL_AUTH_DB_PATH=/data/sentinel_auth.db
SENTINEL_POLICY_FILE=/config/policy.json
SENTINEL_SIGNING_SECRET=change-this-in-production
SENTINEL_PUBLIC_BASE_URL=http://localhost:8000
SENTINEL_ENABLE_DEV_BOOTSTRAP=false
SENTINEL_RATE_LIMIT_PER_MINUTE=120
