VARDEN_ENV=prod
VARDEN_HOST=0.0.0.0
VARDEN_PORT=8000
VARDEN_DB_PATH=/data/varden.db
VARDEN_AUTH_DB_PATH=/data/varden_auth.db
VARDEN_POLICY_FILE=/config/policy.json
